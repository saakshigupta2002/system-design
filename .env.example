# Microsoft Clarity project ID (from clarity.microsoft.com → project → Settings → Overview)
# Leave unset in local dev to keep dev sessions out of the Clarity dashboard.
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Self-hosted Snag session watcher. The project key is the public site key from
# your Snag dashboard (Settings → Install the SDK). Leave unset to disable
# recording (e.g. in local dev). Endpoint defaults to the live ingest deploy.
NEXT_PUBLIC_SNAG_PROJECT_KEY=
NEXT_PUBLIC_SNAG_ENDPOINT=https://snag-deploy-ingest.vercel.app
